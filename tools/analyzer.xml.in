<tool id="neutrons_isaac_analyzer" name="Analyzer" version="0.4.0" profile="22.01">
    <description>Agentic automated analysis tool for reflectivity data using LLM models.</description>
    <creator>
        <person name="Mat Doucet"/>
        <organization url="https://www.ornl.gov/" name="ORNL"/>
    </creator>
    <requirements>
        <container type="docker" shell="/bin/bash">ghcr.io/mdoucet/analyzer:sha-177d9e5-slim</container>
        <credentials name="llm_credentials" version="1.0"
                     label="LLM Credentials"
                     description="Credentials for accessing LLM API.">
            <secret name="llm_api_key"
                    inject_as_env="LLM_API_KEY"
                    optional="false"
                    label="LLM API Key"
                    description="Your LLM API key."/>
        </credentials>
    </requirements>
    <inputs>
        <param name="config_json" type="data" format="json" label="JSON Configuration" optional="false"
               help="A workflow-state JSON (from the reduction step). Provides the reduced reflectivity file, the context file, the sequence total, the output directory, and the LLM endpoint."/>
        <param name="llm_provider" type="text" value="local" label="LLM Provider" help="Fills state.inputs.operator.llm.provider only if the state leaves it blank."/>
        <param name="llm_model" type="text" value="gpt-4" label="LLM Model" help="Fills state.inputs.operator.llm.model only if blank."/>
        <param name="llm_base_url" type="text" value="https://aoai-eastus-bead.openai.azure.com/openai/v1/" label="LLM Endpoint" help="Fills state.inputs.operator.llm.base_url only if blank."/>
    </inputs>

    <configfiles>
        <configfile name="ndip_shim">#raw
@NDIP_SHIM@
#end raw</configfile>
    </configfiles>

    <outputs>
        <data format="txt" name="output" label="Analyzer Console Output"></data>
        <data name="output_model" format="txt" label="Analyzer Model"></data>
        <data format="json" name="updated_config" label="Updated JSON Configuration"></data>
    </outputs>
    <command detect_errors="exit_code"><![CDATA[
        SHIM='$ndip_shim' &&

        ## Fill any blank LLM fields in the state from the Galaxy inputs.
        python "\$SHIM" set-llm '$config_json' '$llm_provider' '$llm_model' '$llm_base_url' _state_in.json &&

        ## Export the resolved LLM endpoint so both plan-data and aure analyze
        ## (which read LLM_* from the environment) pick it up.
        export LLM_PROVIDER=`python "\$SHIM" get _state_in.json inputs.operator.llm.provider` &&
        export LLM_MODEL=`python "\$SHIM" get _state_in.json inputs.operator.llm.model` &&
        export LLM_BASE_URL=`python "\$SHIM" get _state_in.json inputs.operator.llm.base_url` &&

        OUTPUT_DIR=`python "\$SHIM" get _state_in.json inputs.operator.output_directory` &&
        ## Per-run subdir (<output_directory>/<run>) keeps analysis artifacts of
        ## different runs from overwriting each other; reduction stays in OUTPUT_DIR.
        RUN_DIR=`python "\$SHIM" rundir _state_in.json` &&
        RESULTS_DIR="\$RUN_DIR/results" &&
        mkdir -p "\$RUN_DIR"/plan "\$RESULTS_DIR" "\$RUN_DIR"/reports &&

        ## ---- plan-data: gate the (expensive) agentic fit on sequence completeness ----
        ## The plan projection feeds plan-data the reduced partial file and the
        ## scientist's context file, so the context is distilled into the job YAML
        ## (describe / states / model_name) that aure consumes below.
        echo "=== plan-data ===" | tee -a $output &&
        PLAN_ARGS=`python "\$SHIM" project-out plan _state_in.json` &&
        eval plan-data \$PLAN_ARGS --result-out _plan_result.json
                > >(tee -a $output) 2> >(tee -a $output >&2);
        PLAN_RC=\$? &&
        python "\$SHIM" merge-in plan _state_in.json _plan_result.json \$PLAN_RC _plan_state.json &&
        if [ "\$PLAN_RC" -ne 0 ]; then
            cp _plan_state.json '$updated_config';
            echo "plan-data failed (exit \$PLAN_RC)" | tee -a $output >&2;
            exit \$PLAN_RC;
        fi &&

        PERFORM_ASSEMBLY=`python "\$SHIM" get _plan_state.json stages.analysis.params.perform_assembly` &&
        echo "perform_assembly=\$PERFORM_ASSEMBLY" | tee -a $output &&

        if [ "\$PERFORM_ASSEMBLY" = "True" ]; then
            echo "=== aure analyze (agentic fit + refinement) ===" | tee -a $output;
            JOB_YAML=`python "\$SHIM" get _plan_state.json stages.analysis.artifacts.job_yaml`;
            ## aure resolves the basename `states` data paths against the setup
            ## file's own directory, so stage the plan next to the reduced data.
            JOB_LOCAL="\$OUTPUT_DIR/`basename "\$JOB_YAML"`";
            cp "\$JOB_YAML" "\$JOB_LOCAL";
            aure analyze -c "\$JOB_LOCAL" -o "\$RESULTS_DIR" -v
                    > >(tee -a $output) 2> >(tee -a $output >&2);
            ANALYZE_RC=\$?;
            echo "--- aure analyze exit code: \$ANALYZE_RC ---" | tee -a $output;
            ## aure copies the best-fit problem.json to the top of its output dir.
            MODEL="\$RESULTS_DIR/problem.json";
            if [ "\$ANALYZE_RC" -eq 0 ] && [ -f "\$MODEL" ]; then
                printf '{"status":"ok","artifacts":{"problem_json":"%s"}}' "\$MODEL" > _analyze_result.json;
            else
                printf '{"status":"failed","messages":[{"level":"error","text":"aure analyze did not produce problem.json"}]}' > _analyze_result.json;
            fi;
            python "\$SHIM" merge-in analyze _plan_state.json _analyze_result.json \$ANALYZE_RC '$updated_config';
            if [ "\$ANALYZE_RC" -ne 0 ]; then
                echo "ERROR: aure analyze failed with exit code \$ANALYZE_RC" | tee -a $output >&2;
            fi;
        else
            echo "analysis.perform_assembly is false; skipping aure analyze." | tee -a $output;
            cp _plan_state.json '$updated_config';
        fi &&

        echo "=== post-run inventory ===" | tee -a $output &&
        (ls -la "\$RESULTS_DIR" 2>&1 || true) | tee -a $output &&

        PROBLEM_JSON=`python "\$SHIM" get '$updated_config' stages.analysis.artifacts.problem_json` &&
        if [ -n "\$PROBLEM_JSON" ] && [ -f "\$PROBLEM_JSON" ]; then
            echo "Selected problem.json: \$PROBLEM_JSON" | tee -a $output;
            cat "\$PROBLEM_JSON" > $output_model;
        else
            echo "(no problem.json emitted; writing empty output_model)" | tee -a $output >&2;
            : > $output_model;
        fi
    ]]></command>
</tool>
